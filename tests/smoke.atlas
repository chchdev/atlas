mold Beacon {
	seed active <- true;
	seed watts <- 12;
}

globe combine(a, b) {
	return a + b;
}

globe arithmetic(a, b) {
	seed unit <- craft(Beacon);
	seed counter <- 3;
	echo combine(a, b);
	echo a - b;
	echo a * b;
	echo a / b;
	orbit(counter) {
		echo counter;
		counter <- counter - 1;
		continue;
		echo 999;
	}
	seed stopper <- 5;
	orbit(stopper) {
		stopper <- stopper - 1;
		echo stopper;
		break;
		counter <- counter - 1;
	}
	echo unit.active;
	unit.watts <- unit.watts + 8;
	echo unit.watts;
	echo kind(unit);
	echo as_number(unit.active);
	echo kind(as_text(a));
	return unit.watts;
}

ignite arithmetic(10, 5);
