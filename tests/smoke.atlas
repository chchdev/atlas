mold Beacon {
	seed active <- true;
	seed watts <- 12;
}

mold Animal {
	seed name <- as_text(0);
}

mold Dog <- Animal {
	seed power <- 0;
}

globe Animal_voice(self) {
	return 1;
}

globe Dog_voice(self) {
	return 2;
}

globe Dog_construct(self, name, power) {
	self.name <- name;
	self.power <- power;
	return 0;
}

globe combine(a, b) {
	return a + b;
}

globe arithmetic(a, b) {
	seed unit <- craft(Beacon);
	seed counter <- 3;
	echo combine(a, b);
	echo a - b;
	echo a * b;
	echo a / b;
	orbit(counter) {
		echo counter;
		counter <- counter - 1;
		continue;
		echo 999;
	}
	seed stopper <- 5;
	orbit(stopper) {
		stopper <- stopper - 1;
		echo stopper;
		break;
		counter <- counter - 1;
	}
	echo unit.active;
	unit.watts <- unit.watts + 8;
	echo unit.watts;
	echo kind(unit);
	echo as_number(unit.active);
	echo kind(as_text(a));
	seed ledger <- vault();
	seed slot <- as_text(42);
	stash(ledger, slot, 9001);
	echo kind(ledger);
	echo has(ledger, slot);
	echo pull(ledger, slot);
	echo drop(ledger, slot);
	echo has(ledger, slot);
	seed pet <- craft(Dog, as_text(77), 9);
	echo pet.name;
	echo pet.power;
	echo pet.voice();
	return unit.watts;
}

ignite arithmetic(10, 5);
