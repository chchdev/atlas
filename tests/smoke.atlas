mold Beacon {
	seed active <- true;
	seed watts <- 12;
}

globe combine(a, b) {
	return a + b;
}

globe arithmetic(a, b) {
	seed unit <- craft(Beacon);
	echo combine(a, b);
	echo a - b;
	echo a * b;
	echo a / b;
	echo unit.active;
	unit.watts <- unit.watts + 8;
	echo unit.watts;
	echo kind(unit);
	echo as_number(unit.active);
	echo kind(as_text(a));
	return unit.watts;
}

ignite arithmetic(10, 5);
